{
  "ros_sources": [
    {
      "topic": "/lotusim/{agent}/pose",
      "description": "Position GPS en temps r\u00e9el (lat/lon)"
    }
  ],
  "event_triggers": [
    {
      "label": "Intrus détecté à proximité",
      "condition": "distance_lt",
      "target_pattern": "__intruder__",
      "threshold": 0.003,
      "sets_variable": "intruder_nearby",
      "source_topic": "/lotusim/{agent}/pose"
    },
    {
      "label": "Intrus hors de portée (échappé)",
      "condition": "distance_gt",
      "target_pattern": "__intruder__",
      "threshold": 0.01,
      "sets_variable": "intruder_escaped",
      "source_topic": "/lotusim/{agent}/pose"
    }
  ],
  "resolve_tokens": {
    "__intruder__": "__intruder__",
    "__base_location__": "__base__",
    "__patrol__": "__patrol__",
    "__protege__": "__protege__",
    "agent1": "agent1",
    "agent2": "agent2",
    "agent3": "agent3",
    "intruder": "intruder",
    "escorteur": "escorteur",
    "__soutien__": "escorteur",
    "cargo": "cargo"
